.container {
  height: 100vh;
  background: #f5f5f5;
}

.header {
  padding: 20rpx 30rpx;
  background: white;
  border-bottom: 1rpx solid #eee;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.menu-scroll {
  flex: 1;
  padding: 20rpx;
}

.menu-category {
  margin-bottom: 40rpx;
}

.category-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  display: block;
}

.menu-item {
  display: flex;
  align-items: center;
  background: white;
  margin-bottom: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.item-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
}

.item-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.item-price {
  font-size: 24rpx;
  color: #ff5722;
  font-weight: bold;
}

.add-btn {
  background: #3cc51f;
  color: white;
  border-radius: 50%;
  width: 72rpx;
  height: 72rpx;
  font-size: 36rpx;
  line-height: 48rpx;
}

.cart-section {
  position: fixed;
  bottom: 200rpx;
  left: 0;
  right: 0;
  background: white;
  border-top: 2rpx solid #eee;
}

.cart-header {
  display: flex;
  justify-content: space-between;
  padding: 30rpx;
  font-size: 32rpx;
}

.total-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff5722;
}

.submit-btn {
  position: fixed;
  bottom: 100rpx;
  left: 30rpx;
  right: 30rpx;
  background: linear-gradient(45deg, #3cc51f, #4ee04e);
  color: white;
  border-radius: 100rpx;
  font-size: 32rpx;
  height: 90rpx;
  line-height: 90rpx;
}

.order-item {
  background: white;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.order-status {
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: white;
}

.status-pending { background: #ff9800; }
.status-approved { background: #3cc51f; }
.status-rejected { background: #f44336; }
